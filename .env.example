# ============================================
# FamiliDocs - Variables d'environnement
# ============================================
# Copiez ce fichier en .env et adaptez les valeurs

# Mode de l'application (development, testing, production)
FLASK_ENV=development

# Cle secrete pour les sessions (OBLIGATOIRE en production)
# Generez avec : python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=votre_cle_secrete_ici

# Base de donnees PostgreSQL (OBLIGATOIRE - partagee entre web et desktop .exe)
# Les deux modes (web et .exe) utilisent la meme BDD pour synchroniser les donnees
DATABASE_URL=postgresql://jagadmin:pass@localhost:5432/familidocs

# Dossier d'upload des fichiers
# FAMILIDOCS_UPLOAD_FOLDER=/path/to/uploads

# Dossier des sauvegardes
# FAMILIDOCS_BACKUP_FOLDER=/path/to/backups

# Mot de passe administrateur par defaut (premier lancement)
# ADMIN_DEFAULT_PASSWORD=Admin123!

# Cle de chiffrement pour les documents sensibles
# Generez avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=votre_cle_fernet_ici

# Niveau de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
